{
  "name": "@hammies/inbox",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "tsc -b && vitest run",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\" --ignore-path .gitignore",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "migrate:credentials": "tsx server/scripts/migrate-env-to-vault.ts",
    "start": "npm run build && nohup node --env-file=../../.env --import tsx/esm server/index.ts --workspace ../agent > /tmp/inbox.log 2>&1 & echo $! > /tmp/inbox.pid && echo \"Started (PID $(cat /tmp/inbox.pid)), logs at /tmp/inbox.log\"",
    "stop": "if [ -f /tmp/inbox.pid ] && kill -0 $(cat /tmp/inbox.pid) 2>/dev/null; then kill $(cat /tmp/inbox.pid) && rm /tmp/inbox.pid && echo 'Stopped'; else echo 'Not running'; rm -f /tmp/inbox.pid; fi",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@babel/standalone": "^7.29.2",
    "@hammies/frontend": "file:../frontend",
    "@hono/node-server": "^1.8.0",
    "@tailwindcss/browser": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/query-persist-client-core": "^5.92.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.21",
    "@tiptap/extension-code-block-lowlight": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "better-sqlite3": "^11.8.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "hono": "^4.12.0",
    "idb-keyval": "^6.2.2",
    "lowlight": "^3.3.0",
    "motion": "^12.35.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.1.1",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "selfsigned": "^5.5.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
