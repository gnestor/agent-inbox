# PostgreSQL connection (required)
DATABASE_URL=postgresql://inbox:password@grants-mac-mini.tail21f7c3.ts.net:5432/inbox

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
VAULT_SECRET=
# Set to any value to disable backfill/curation scheduling (useful when running multiple server instances)
DISABLE_BACKFILL=

# Claude / Anthropic
# API key used by title generation and curation (direct Anthropic SDK calls).
# Agent sessions use the user's Claude subscription via CLAUDE_CODE_OAUTH_TOKEN — ANTHROPIC_API_KEY
# is intentionally excluded from the agent env (see session-manager.ts buildAgentEnv).
ANTHROPIC_API_KEY=

# Default model for new and resumed agent sessions (Claude Agent SDK).
# Accepts full model IDs (e.g. claude-sonnet-4-6) or aliases (sonnet, haiku, opus).
# Falls back to the Agent SDK default when unset.
SESSION_MODEL=

# Model used for automatic session title generation (direct Anthropic API call).
# Defaults to claude-haiku-4-5-20251001 when unset.
TITLE_MODEL=

# Model used by background curation sessions.
# Defaults to claude-haiku-4-5-20251001 when unset.
CURATION_MODEL=
